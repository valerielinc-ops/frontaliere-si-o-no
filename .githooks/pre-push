#!/bin/sh
# Pre-push hook: Run tests, build verification, quiz freshness, and job scraping before pushing
#
# ── Regole editoriali per la creazione articoli (create-article.mjs) ──
#
# 1. ANTI-AI: Gli articoli devono sembrare scritti da un giornalista umano.
#    Niente frasi generiche ("in un mondo sempre più...", "è fondamentale...").
#    Stile diretto, dati concreti, esempi reali dal Ticino.
#
# 2. IMMAGINI: Genera immagini contestuali con Imagen 3 ("Nano Banano").
#    Fallback: immagini del Ticino dalla cartella /images/places/.
#    Formato 16:9, no persone, salvataggio in /public/images/blog/{id}.jpg.
#
# 3. ALT TAG & SEO IMMAGINI: Ogni immagine ha ALT descrittivo (4 lingue)
#    e structured data ImageObject per indicizzazione Google/Bing.
#
# 4. DATI STRUTTURATI: Schema.org Article + ImageObject + breadcrumb
#    per ogni articolo, sia per Google che per Bing.
#
# 5. SITEMAP: Ogni nuovo articolo viene aggiunto automaticamente a
#    public/sitemap.xml con hreflang per tutte e 4 le lingue.
#
# 6. RILEVANZA TICINO: Le notizie devono essere rilevanti per i
#    frontalieri del Canton Ticino, non generiche/mondiali.
#
# 7. CTA: Ogni articolo DEVE avere un invito all'azione che rimandi
#    a un comparatore o strumento del sito. Fallback: comparatore stipendi.
#

# ── Load environment variables (GEMINI_API_KEY etc.) ──
[ -f "$HOME/.bashrc" ] && . "$HOME/.bashrc"

# ── Blog article generation (DISABLED by default — runs via GitHub Actions) ──
# Articles are now generated automatically every hour by the CI workflow:
#   .github/workflows/generate-article.yml
#
# To generate an article locally (opt-in), run:
#   ARTICLE_GEN=1 git push
# Or use the npm script directly:
#   npm run new-article

if [ "$ARTICLE_GEN" = "1" ]; then
  echo "📰 Generazione articolo locale (ARTICLE_GEN=1)..."
  echo "   Scansione fonti ticinesi e generazione con Gemini AI..."
  node scripts/create-article.mjs
  ARTICLE_EXIT=$?
  if [ $ARTICLE_EXIT -ne 0 ]; then
    echo "⚠️  Creazione articolo fallita (exit code: $ARTICLE_EXIT)."
    echo "   Rollback modifiche parziali..."
    git checkout -- . 2>/dev/null
    echo "   Il push prosegue comunque."
    echo ""
  else
    git add -A
    git commit -m "📰 Auto-generated blog article"
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "✅ Nuovo articolo generato e committato."
    echo "⚠️  Esegui di nuovo 'git push' per includere l'articolo."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    exit 1
  fi
else
  echo "ℹ️  Articoli generati automaticamente via GitHub Actions (ogni ora, 24/7)"
  echo "   Per generare localmente: ARTICLE_GEN=1 git push"
  echo ""
fi

echo "🏗️  Verifying build..."
npx vite build --logLevel error 2>&1
if [ $? -ne 0 ]; then
  echo "❌ Build failed. Push aborted."
  exit 1
fi

echo "🧪 Running test suite..."
npm test
if [ $? -ne 0 ]; then
  echo "❌ Tests failed. Push aborted."
  exit 1
fi

echo "🧩 Validating structured data JSON-LD..."
npm run validate:structured-data
if [ $? -ne 0 ]; then
  echo "❌ Invalid structured data found. Push aborted."
  exit 1
fi

echo "🔑 Validating jobs crawler company key resolution..."
npm run validate:jobs-crawler-keys
if [ $? -ne 0 ]; then
  echo "❌ Jobs crawler key validation failed. Push aborted."
  exit 1
fi

# WhatsNew pending releases enforcement (auto-apply every 20 commits)
PENDING_RELEASES="data/pending-releases.json"
if [ -f "$PENDING_RELEASES" ]; then
  PENDING_COUNT=$(node -e "try{const e=JSON.parse(require('fs').readFileSync('$PENDING_RELEASES','utf8'));console.log(Array.isArray(e)?e.length:0)}catch{console.log(0)}" 2>/dev/null)
  if [ "$PENDING_COUNT" -ge 20 ] 2>/dev/null; then
    echo ""
    echo "📋 WhatsNew: $PENDING_COUNT user-facing commit(s) pending release notes (threshold: 20)."
    echo "   🧭 Regole generazione: testo umano/non tecnico, massimo 5 punti, localizzazione completa, link pagina quando pertinente."
    echo "   Auto-applying release notes before push..."
    npm run update-whats-new -- --apply
    if [ $? -ne 0 ]; then
      echo "❌ Failed to auto-update WhatsNew. Push aborted."
      exit 1
    fi

    # Stage only generated WhatsNew files
    git add components/community/WhatsNewModal.tsx \
      services/locales/it-core.ts \
      services/locales/en-core.ts \
      services/locales/de-core.ts \
      services/locales/fr-core.ts \
      data/pending-releases.json 2>/dev/null

    if git diff --cached --quiet -- \
      components/community/WhatsNewModal.tsx \
      services/locales/it-core.ts \
      services/locales/en-core.ts \
      services/locales/de-core.ts \
      services/locales/fr-core.ts \
      data/pending-releases.json
    then
      echo "   ℹ️  No file changes generated by update-whats-new."
    else
      git commit -m "chore(release): sync whats-new notes"
      if [ $? -ne 0 ]; then
        echo "❌ Auto-commit for WhatsNew failed. Push aborted."
        exit 1
      fi
      echo "✅ WhatsNew synchronized and committed."
      echo "⚠️  Push aborted intentionally: run 'git push' again to include the new commit."
      exit 1
    fi
    echo ""
  elif [ "$PENDING_COUNT" -gt 0 ] 2>/dev/null; then
    echo "📋 WhatsNew: $PENDING_COUNT pending commit(s) — will auto-generate at 20."
  fi
fi

# Quiz freshness reminder
QUIZ_FILE="components/WeeklyQuiz.tsx"
if [ -f "$QUIZ_FILE" ]; then
  QUIZ_LAST_MODIFIED=$(git log -1 --format="%at" -- "$QUIZ_FILE" 2>/dev/null || echo 0)
  NOW=$(date +%s)
  FOUR_WEEKS=$((28 * 24 * 60 * 60))
  if [ "$QUIZ_LAST_MODIFIED" -gt 0 ] && [ $((NOW - QUIZ_LAST_MODIFIED)) -gt $FOUR_WEEKS ]; then
    echo ""
    echo "⚠️  REMINDER: WeeklyQuiz.tsx hasn't been updated in over 4 weeks."
    echo "   Consider reviewing/updating the QUIZ_POOL questions."
    echo ""
  fi
fi

# Job board freshness check and optional scrape
JOBS_FILE="data/jobs.json"
JOBS_META="data/jobs-meta.json"
if [ -f "$JOBS_META" ]; then
  JOBS_LAST_UPDATED=$(cat "$JOBS_META" 2>/dev/null | grep -o '"lastUpdated":"[^"]*"' | cut -d'"' -f4)
  if [ -n "$JOBS_LAST_UPDATED" ]; then
    JOBS_TIMESTAMP=$(date -j -f "%Y-%m-%dT%H:%M:%S" "${JOBS_LAST_UPDATED%%.*}" +%s 2>/dev/null || date -d "$JOBS_LAST_UPDATED" +%s 2>/dev/null || echo 0)
    NOW=$(date +%s)
    ONE_WEEK=$((7 * 24 * 60 * 60))
    if [ "$JOBS_TIMESTAMP" -gt 0 ] && [ $((NOW - JOBS_TIMESTAMP)) -gt $ONE_WEEK ]; then
      echo ""
      echo "📋 Job board data is over 1 week old."
      echo "   Running job scraper to refresh listings..."
      npx ts-node scripts/update-jobs.ts 2>&1 || echo "   ⚠️ Job scraper encountered issues (non-blocking)"
      # Stage updated job files if they changed
      if git diff --quiet data/jobs.json data/jobs-meta.json 2>/dev/null; then
        echo "   ℹ️  No changes to job data"
      else
        git add data/jobs.json data/jobs-meta.json 2>/dev/null
        echo "   ✅ Job data updated and staged for commit"
      fi
      echo ""
    fi
  fi
fi

# ── CI Health Check: verify latest workflow runs for errors/warnings ──
if command -v gh >/dev/null 2>&1; then
  echo ""
  echo "🔍 Checking latest CI workflow runs for errors/warnings..."
  CI_ISSUES=0

  for WORKFLOW in "Generate Blog Article" "Deploy to GitHub Pages"; do
    # Get the latest completed run
    RUN_JSON=$(gh run list --workflow "$WORKFLOW" --status completed --limit 1 --json databaseId,conclusion,startedAt,displayTitle 2>/dev/null)
    if [ -z "$RUN_JSON" ] || [ "$RUN_JSON" = "[]" ]; then
      echo "   ⚠️  $WORKFLOW: nessuna run trovata"
      continue
    fi

    RUN_ID=$(echo "$RUN_JSON" | grep -o '"databaseId":[0-9]*' | head -1 | cut -d: -f2)
    CONCLUSION=$(echo "$RUN_JSON" | grep -o '"conclusion":"[^"]*"' | head -1 | cut -d'"' -f4)
    TITLE=$(echo "$RUN_JSON" | grep -o '"displayTitle":"[^"]*"' | head -1 | cut -d'"' -f4)

    if [ "$CONCLUSION" = "failure" ]; then
      echo ""
      echo "   ❌ $WORKFLOW — FAILED (run #$RUN_ID)"
      echo "      Title: $TITLE"

      # Fetch failed step logs (annotations = error messages)
      ANNOTATIONS=$(gh run view "$RUN_ID" 2>/dev/null | grep -E "^X |^!|failed|error|Error|FAIL" | head -15)
      if [ -n "$ANNOTATIONS" ]; then
        echo "      Errors:"
        echo "$ANNOTATIONS" | while IFS= read -r line; do echo "        $line"; done
      fi

      # Fetch the specific failed step logs for more detail
      FAILED_LOGS=$(gh run view "$RUN_ID" --log-failed 2>/dev/null | tail -30)
      if [ -n "$FAILED_LOGS" ]; then
        echo "      Failed step logs (last 30 lines):"
        echo "$FAILED_LOGS" | while IFS= read -r line; do echo "        $line"; done
      fi

      CI_ISSUES=$((CI_ISSUES + 1))
      echo ""
    elif [ "$CONCLUSION" = "success" ]; then
      if [ "$WORKFLOW" = "Generate Blog Article" ]; then
        echo "   ✅ $WORKFLOW — OK (run #$RUN_ID, warning scan skipped)"
        continue
      fi
      # Even on success, check for warnings in logs
      WARNINGS=$(gh run view "$RUN_ID" --log 2>/dev/null | grep -iE "⚠️|warn:|warning:|WARN |deprecat|non configurata|expired|scadut|fallita|errore" | grep -viE "chunkSizeWarning|ExperimentalWarning|--log-level|logLevel|DeprecationWarning:.*punycode|source map|sourcemap|Run tests.*⚠️|npm warn deprecated|Firestore rate read failed|Remote Config non supportato|not available from Remote Config|RECAPTCHA_SITE_KEY non trovata|aborted due to timeout|Firebase secrets not set|GSC secrets not configured|Request GSC indexing for updated pages|Failed to get access token — skipping indexing|\\$HTTP_CODE\\): \\$url|Failed \\(403\\): https://www\\.frontaliereticino\\.ch/|daily url submission quota" | sort -u | head -20)
      if [ -n "$WARNINGS" ]; then
        echo ""
        echo "   ⚠️  $WORKFLOW — SUCCESS ma con warning (run #$RUN_ID)"
        echo "      Warnings trovati:"
        echo "$WARNINGS" | while IFS= read -r line; do
          # Trim the line to 120 chars for readability
          TRIMMED=$(echo "$line" | cut -c1-120)
          echo "        $TRIMMED"
        done
        CI_ISSUES=$((CI_ISSUES + 1))
        echo ""
      else
        echo "   ✅ $WORKFLOW — OK (run #$RUN_ID)"
      fi
    else
      echo "   ⚠️  $WORKFLOW — $CONCLUSION (run #$RUN_ID)"
      CI_ISSUES=$((CI_ISSUES + 1))
    fi
  done

  if [ $CI_ISSUES -gt 0 ]; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "⚠️  CI Health Check: $CI_ISSUES workflow(s) con problemi."
    echo "   Verifica e correggi prima del prossimo push se possibile."
    echo "   Dettagli: gh run view <RUN_ID> --log"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    # Non-blocking: report but don't abort push
    # To make it blocking, uncomment: exit 1
  else
    echo "   ✅ Tutti i workflow CI sono puliti"
  fi
else
  echo ""
  echo "ℹ️  gh CLI non trovato — skip CI health check"
  echo "   Installa con: brew install gh"
fi

echo "✅ All checks passed. Pushing..."
exit 0
