# Cache headers for GitHub Pages
# Static assets with hashed filenames — cache for 1 year
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Icons — cache for 1 month
/icons/*
  Cache-Control: public, max-age=2592000

# HTML — short cache with revalidation
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Manifest — short cache
/manifest.webmanifest
  Cache-Control: public, max-age=3600

# Sitemap — cache for 1 day
/sitemap.xml
  Cache-Control: public, max-age=86400
  Content-Type: application/xml; charset=utf-8

# Robots.txt — cache for 1 day
/robots.txt
  Cache-Control: public, max-age=86400

# AI-readable site descriptions — cache for 1 day
/llms.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8
  X-Robots-Tag: noindex

/llms-full.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8
  X-Robots-Tag: noindex

/.well-known/llms.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8

/.well-known/ai-plugin.json
  Cache-Control: public, max-age=86400
  Content-Type: application/json; charset=utf-8

# IndexNow key — long cache
/*.txt
  Cache-Control: public, max-age=2592000

# Security headers
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Permissions-Policy: camera=(), microphone=(), geolocation=(self)
  # same-origin-allow-popups: allows Firebase Auth popup windows to call
  # window.close() and postMessage back to the opener.  Without this,
  # COOP: same-origin would silently block the handshake and leave the
  # user stuck on a blank popup.  Note: the auth.frontaliereticino.ch
  # handler page must also NOT set COOP:same-origin (Firebase controls that).
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.googleapis.com https://*.gstatic.com https://*.google.com https://*.googletagmanager.com https://*.googlesyndication.com https://*.doubleclick.net https://pagead2.googlesyndication.com https://*.clarity.ms https://eu.acsbapp.com https://*.firebaseapp.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://unpkg.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.googleapis.com https://*.gstatic.com https://flagcdn.com https://logo.clearbit.com https://*.tile.openstreetmap.org https://*.googleusercontent.com https://*.google.com https://*.googlesyndication.com; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://*.firebaseapp.com https://*.google-analytics.com https://*.analytics.google.com https://*.googletagmanager.com https://*.clarity.ms https://eu.acsbapp.com https://cloudflareinsights.com; frame-src 'self' https://*.firebaseapp.com https://*.google.com https://*.googlesyndication.com https://eu.acsbapp.com; object-src 'none'; base-uri 'self'
